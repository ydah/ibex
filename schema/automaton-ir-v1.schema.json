{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ydah/ibex/main/schema/automaton-ir-v1.schema.json",
  "title": "Ibex Automaton IR version 1",
  "description": "The self-contained parser automaton exchanged between Ibex analysis and code generation stages.",
  "type": "object",
  "required": [
    "ibex_ir",
    "schema_version",
    "algorithm",
    "grammar_digest",
    "grammar",
    "states",
    "conflict_summary"
  ],
  "properties": {
    "ibex_ir": {
      "const": "automaton"
    },
    "schema_version": {
      "const": 1
    },
    "algorithm": {
      "enum": [
        "slr",
        "lalr1",
        "lr1"
      ]
    },
    "grammar_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "grammar": {
      "$ref": "grammar-ir-v1.schema.json"
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/state"
      }
    },
    "conflict_summary": {
      "$ref": "#/$defs/conflict_summary"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "item": {
      "type": "object",
      "required": [
        "production",
        "dot",
        "lookaheads"
      ],
      "properties": {
        "production": {
          "type": "integer",
          "minimum": -1
        },
        "dot": {
          "type": "integer",
          "minimum": 0
        },
        "lookaheads": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "shift_action": {
      "type": "object",
      "required": [
        "type",
        "state"
      ],
      "properties": {
        "type": {
          "const": "shift"
        },
        "state": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "reduce_action": {
      "type": "object",
      "required": [
        "type",
        "production"
      ],
      "properties": {
        "type": {
          "const": "reduce"
        },
        "production": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "accept_action": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "accept"
        }
      },
      "additionalProperties": false
    },
    "error_action": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "error"
        }
      },
      "additionalProperties": false
    },
    "parser_action": {
      "oneOf": [
        {
          "$ref": "#/$defs/shift_action"
        },
        {
          "$ref": "#/$defs/reduce_action"
        },
        {
          "$ref": "#/$defs/accept_action"
        },
        {
          "$ref": "#/$defs/error_action"
        }
      ]
    },
    "nullable_parser_action": {
      "oneOf": [
        {
          "$ref": "#/$defs/parser_action"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolution": {
      "type": "object",
      "required": [
        "by",
        "chose"
      ],
      "properties": {
        "by": {
          "enum": [
            "definition_order",
            "default_shift",
            "precedence",
            "associativity"
          ]
        },
        "chose": {
          "oneOf": [
            {
              "enum": [
                "shift",
                "reduce",
                "error"
              ]
            },
            {
              "type": "integer",
              "minimum": 0
            }
          ]
        },
        "associativity": {
          "enum": [
            "left",
            "right",
            "nonassoc"
          ]
        }
      },
      "additionalProperties": false
    },
    "shift_reduce_conflict": {
      "type": "object",
      "required": [
        "type",
        "symbol",
        "shift_to",
        "reduce",
        "resolution"
      ],
      "properties": {
        "type": {
          "const": "shift_reduce"
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "shift_to": {
          "type": "integer",
          "minimum": 0
        },
        "reduce": {
          "type": "integer",
          "minimum": 0
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        }
      },
      "additionalProperties": false
    },
    "reduce_reduce_conflict": {
      "type": "object",
      "required": [
        "type",
        "symbol",
        "reductions",
        "resolution"
      ],
      "properties": {
        "type": {
          "const": "reduce_reduce"
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "reductions": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "required": [
        "id",
        "items",
        "transitions",
        "actions",
        "gotos",
        "default_action",
        "conflicts"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        },
        "transitions": {
          "$ref": "#/$defs/state_map"
        },
        "actions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/parser_action"
          }
        },
        "gotos": {
          "$ref": "#/$defs/state_map"
        },
        "default_action": {
          "$ref": "#/$defs/nullable_parser_action"
        },
        "conflicts": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/shift_reduce_conflict"
              },
              {
                "$ref": "#/$defs/reduce_reduce_conflict"
              }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "state_map": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "conflict_summary": {
      "type": "object",
      "required": [
        "sr",
        "resolved_sr",
        "rr",
        "expected_sr",
        "expectation_met"
      ],
      "properties": {
        "sr": {
          "type": "integer",
          "minimum": 0
        },
        "resolved_sr": {
          "type": "integer",
          "minimum": 0
        },
        "rr": {
          "type": "integer",
          "minimum": 0
        },
        "expected_sr": {
          "type": "integer",
          "minimum": 0
        },
        "expectation_met": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
